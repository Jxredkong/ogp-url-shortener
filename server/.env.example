# Server
PORT=3000
NODE_ENV=development

# Public base URL used to compose short links (no trailing slash)
PUBLIC_BASE_URL=http://localhost:3000

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ogp_url_shortener

# Access gate — anyone with this key can mint links via the dashboard.
# Public short-code redirects (GET /:code) remain open by design.
ACCESS_KEY=change-me-please
# JWT_SECRET is used to sign session tokens; falls back to ACCESS_KEY if unset.
JWT_SECRET=

