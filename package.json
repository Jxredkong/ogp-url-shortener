{
  "name": "ogp-url-shortener",
  "private": true,
  "version": "0.1.0",
  "description": "URL shortener — OGP SWE Intern take-home assessment",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:client",
    "dev:server": "npm --workspace server run dev",
    "dev:client": "npm --workspace client run dev",
    "build": "npm --workspace client run build && npm --workspace server run build",
    "start": "npm --workspace server run start",
    "test": "npm --workspace server run test",
    "lint": "npm --workspace client run lint"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
